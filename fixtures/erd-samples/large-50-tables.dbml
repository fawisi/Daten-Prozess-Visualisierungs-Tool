Table tenants {
  id uuid [pk]
  name varchar(128) [not null]
}

Table users {
  id uuid [pk]
  tenant_id uuid [not null]
  email varchar(255) [not null]
}
Ref: users.tenant_id > tenants.id

Table sessions {
  id uuid [pk]
  user_id uuid [not null]
  expires_at timestamptz [not null]
}
Ref: sessions.user_id > users.id

Table api_keys {
  id uuid [pk]
  user_id uuid [not null]
  secret_hash varchar(128) [not null]
}
Ref: api_keys.user_id > users.id

Table permissions {
  id uuid [pk]
  name varchar(64) [not null]
}

Table role_permissions {
  role_id uuid [pk]
  permission_id uuid [pk]
}
Ref: role_permissions.permission_id > permissions.id

Table roles {
  id uuid [pk]
  name varchar(64) [not null]
}
Ref: role_permissions.role_id > roles.id

Table user_roles {
  user_id uuid [pk]
  role_id uuid [pk]
}
Ref: user_roles.user_id > users.id
Ref: user_roles.role_id > roles.id

Table products {
  id uuid [pk]
  tenant_id uuid [not null]
  sku varchar(64) [not null]
  name varchar(256) [not null]
}
Ref: products.tenant_id > tenants.id

Table product_variants {
  id uuid [pk]
  product_id uuid [not null]
  size varchar(32)
  color varchar(32)
}
Ref: product_variants.product_id > products.id

Table categories {
  id uuid [pk]
  name varchar(128) [not null]
  parent_id uuid
}
Ref: categories.parent_id > categories.id

Table product_categories {
  product_id uuid [pk]
  category_id uuid [pk]
}
Ref: product_categories.product_id > products.id
Ref: product_categories.category_id > categories.id

Table inventory {
  id uuid [pk]
  product_variant_id uuid [not null]
  warehouse_id uuid [not null]
  quantity integer [not null]
}
Ref: inventory.product_variant_id > product_variants.id

Table warehouses {
  id uuid [pk]
  tenant_id uuid [not null]
  name varchar(128) [not null]
}
Ref: warehouses.tenant_id > tenants.id
Ref: inventory.warehouse_id > warehouses.id

Table orders {
  id uuid [pk]
  tenant_id uuid [not null]
  customer_id uuid [not null]
  status varchar(32) [not null]
}
Ref: orders.tenant_id > tenants.id

Table customers {
  id uuid [pk]
  tenant_id uuid [not null]
  email varchar(255) [not null]
}
Ref: customers.tenant_id > tenants.id
Ref: orders.customer_id > customers.id

Table order_items {
  order_id uuid [pk]
  product_variant_id uuid [pk]
  quantity integer [not null]
  unit_price_cents integer [not null]
}
Ref: order_items.order_id > orders.id
Ref: order_items.product_variant_id > product_variants.id

Table payments {
  id uuid [pk]
  order_id uuid [not null]
  amount_cents integer [not null]
  method varchar(32)
}
Ref: payments.order_id > orders.id

Table invoices {
  id uuid [pk]
  order_id uuid [not null]
  issued_at timestamptz [not null]
}
Ref: invoices.order_id > orders.id

Table shipments {
  id uuid [pk]
  order_id uuid [not null]
  tracking_number varchar(64)
  shipped_at timestamptz
}
Ref: shipments.order_id > orders.id

Table addresses {
  id uuid [pk]
  customer_id uuid [not null]
  line1 varchar(256) [not null]
  city varchar(128) [not null]
  country varchar(2) [not null]
}
Ref: addresses.customer_id > customers.id

Table reviews {
  id uuid [pk]
  product_id uuid [not null]
  customer_id uuid [not null]
  rating integer [not null]
  body text
}
Ref: reviews.product_id > products.id
Ref: reviews.customer_id > customers.id

Table cart {
  id uuid [pk]
  customer_id uuid [not null]
}
Ref: cart.customer_id > customers.id

Table cart_items {
  cart_id uuid [pk]
  product_variant_id uuid [pk]
  quantity integer [not null]
}
Ref: cart_items.cart_id > cart.id

Table coupons {
  id uuid [pk]
  code varchar(64) [not null]
  percent_off integer
}

Table coupon_redemptions {
  id uuid [pk]
  coupon_id uuid [not null]
  order_id uuid [not null]
}
Ref: coupon_redemptions.coupon_id > coupons.id
Ref: coupon_redemptions.order_id > orders.id

Table audit_log {
  id uuid [pk]
  actor_id uuid
  action varchar(64) [not null]
  target_type varchar(64)
  target_id uuid
  created_at timestamptz [not null]
}
Ref: audit_log.actor_id > users.id

Table notifications {
  id uuid [pk]
  user_id uuid [not null]
  kind varchar(32) [not null]
  read_at timestamptz
}
Ref: notifications.user_id > users.id

Table webhooks {
  id uuid [pk]
  tenant_id uuid [not null]
  url varchar(512) [not null]
  secret varchar(128)
}
Ref: webhooks.tenant_id > tenants.id

Table webhook_deliveries {
  id uuid [pk]
  webhook_id uuid [not null]
  status varchar(32) [not null]
  delivered_at timestamptz
}
Ref: webhook_deliveries.webhook_id > webhooks.id

Table integrations {
  id uuid [pk]
  tenant_id uuid [not null]
  provider varchar(64) [not null]
  status varchar(32) [not null]
}
Ref: integrations.tenant_id > tenants.id

Table files {
  id uuid [pk]
  tenant_id uuid [not null]
  path varchar(512) [not null]
  size_bytes integer
}
Ref: files.tenant_id > tenants.id

Table feature_flags {
  id uuid [pk]
  tenant_id uuid
  name varchar(64) [not null]
  enabled boolean [not null]
}
Ref: feature_flags.tenant_id > tenants.id

Table plans {
  id uuid [pk]
  name varchar(64) [not null]
  monthly_price_cents integer [not null]
}

Table subscriptions {
  id uuid [pk]
  tenant_id uuid [not null]
  plan_id uuid [not null]
  status varchar(32) [not null]
}
Ref: subscriptions.tenant_id > tenants.id
Ref: subscriptions.plan_id > plans.id

Table tax_rates {
  id uuid [pk]
  country varchar(2) [not null]
  rate_percent decimal [not null]
}

Table currencies {
  code varchar(3) [pk]
  symbol varchar(8)
}

Table exchange_rates {
  id uuid [pk]
  from_code varchar(3) [not null]
  to_code varchar(3) [not null]
  rate decimal [not null]
}
Ref: exchange_rates.from_code > currencies.code
Ref: exchange_rates.to_code > currencies.code

Table locales {
  code varchar(8) [pk]
  name varchar(64) [not null]
}

Table translations {
  id uuid [pk]
  locale varchar(8) [not null]
  key varchar(256) [not null]
  value text
}
Ref: translations.locale > locales.code

Table organisations {
  id uuid [pk]
  tenant_id uuid [not null]
  name varchar(128) [not null]
}
Ref: organisations.tenant_id > tenants.id

Table teams {
  id uuid [pk]
  organisation_id uuid [not null]
  name varchar(128) [not null]
}
Ref: teams.organisation_id > organisations.id

Table team_members {
  team_id uuid [pk]
  user_id uuid [pk]
}
Ref: team_members.team_id > teams.id
Ref: team_members.user_id > users.id

Table projects {
  id uuid [pk]
  team_id uuid [not null]
  name varchar(128) [not null]
}
Ref: projects.team_id > teams.id

Table tasks {
  id uuid [pk]
  project_id uuid [not null]
  title varchar(256) [not null]
  status varchar(32) [not null]
}
Ref: tasks.project_id > projects.id

Table comments {
  id uuid [pk]
  task_id uuid [not null]
  author_id uuid [not null]
  body text
}
Ref: comments.task_id > tasks.id
Ref: comments.author_id > users.id

Table attachments {
  id uuid [pk]
  task_id uuid [not null]
  file_id uuid [not null]
}
Ref: attachments.task_id > tasks.id
Ref: attachments.file_id > files.id
