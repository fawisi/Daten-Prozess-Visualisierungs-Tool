{
  "name": "viso-mcp",
  "version": "1.1.0",
  "description": "Agent-native MCP server for ER (DBML), BPMN process, and C4 System-Landscape visualization. Consulting-ready narrative-to-diagram, Handoff-Bundle export, DE-first UI.",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./dist/preview.css"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "bin": {
    "viso-mcp": "./dist/cli.cjs"
  },
  "main": "./dist/server.cjs",
  "module": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js"
    },
    "./preview.css": "./dist/preview.css",
    "./http-adapter": {
      "import": {
        "types": "./dist/http-adapter.d.ts",
        "default": "./dist/http-adapter.js"
      },
      "require": {
        "types": "./dist/http-adapter.d.cts",
        "default": "./dist/http-adapter.cjs"
      }
    }
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite --config vite.config.ts",
    "size": "size-limit",
    "check:package": "publint",
    "check:types": "attw --pack . --ignore-rules cjs-resolves-to-esm no-resolution",
    "check:release": "npm run build && npm test && npm run check:package && npm run check:types && npm run size"
  },
  "size-limit": [
    {
      "name": "cli (CJS, brotli)",
      "path": "dist/cli.cjs",
      "limit": "60 kB"
    },
    {
      "name": "server (CJS, brotli)",
      "path": "dist/server.cjs",
      "limit": "40 kB"
    },
    {
      "name": "http-adapter (CJS, brotli)",
      "path": "dist/http-adapter.cjs",
      "limit": "35 kB"
    },
    {
      "name": "preview (ESM, brotli)",
      "path": "dist/preview.js",
      "limit": "650 kB"
    }
  ],
  "keywords": [
    "mcp",
    "agent-native",
    "diagram",
    "er-diagram",
    "dbml",
    "bpmn",
    "c4-model",
    "system-landscape",
    "consulting",
    "mermaid",
    "visualization",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabianwillisimon/viso-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/fabianwillisimon/viso-mcp/issues"
  },
  "homepage": "https://github.com/fabianwillisimon/viso-mcp#readme",
  "license": "MIT",
  "overrides": {
    "hono": "^4.12.12"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@dbml/core": "^7.1.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fastest-levenshtein": "^1.0.16",
    "fastify": "^5.8.5",
    "html-to-image": "1.11.11",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@xyflow/react": "^12.0.0",
    "chokidar": "^4.0.0",
    "elkjs": "^0.9.0",
    "fast-check": "^4.7.0",
    "publint": "^0.3.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "ws": "^8.0.0"
  }
}
