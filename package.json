{
  "name": "daten-viz-mcp",
  "version": "0.1.0",
  "description": "Agent-native MCP server for ER diagram visualization",
  "type": "module",
  "bin": {
    "daten-viz-mcp": "./dist/server.cjs",
    "daten-viz": "./dist/cli.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "preview": "vite --config vite.config.ts"
  },
  "keywords": ["mcp", "er-diagram", "database", "visualization", "ai-agent"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@xyflow/react": "^12.0.0",
    "chokidar": "^4.0.0",
    "elkjs": "^0.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "ws": "^8.0.0"
  }
}
