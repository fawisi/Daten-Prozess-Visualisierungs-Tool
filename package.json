    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@xyflow/react": "^12.0.0",
    "chokidar": "^4.0.0",
    "elkjs": "^0.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "ws": "^8.0.0"
  }
